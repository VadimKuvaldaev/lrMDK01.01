<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="896">
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="4" Width="596" Height="39">
            <Button Content="Открыть" Margin="5"/>
            <Button Content="Сохранить" Margin="5"/>
            <Button Content="Закрыть" Margin="5"/>
            <Button Content="Обработать" Margin="5"/>
            <Button Content="О программе" Margin="5"/>
        </StackPanel>


        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="10,-3,0,13">
                <TextBlock Text="Последние документы" FontWeight="Bold"/>
                <ListBox>
                    <ListBoxItem Content="1.txt"/>
                    <ListBoxItem Content="2.txt"/>
                    <ListBoxItem Content="3.txt"/>
                    <ListBoxItem Content="4.txt"/>
                    <ListBoxItem Content="5.txt"/>
                    <ListBoxItem Content="6.txt"/>
                </ListBox>
            </StackPanel>

            <WrapPanel Grid.Column="1" Margin="10">


                <Border Background="AntiqueWhite" Width="80" Height="115" Margin="15">
                    <TextBlock Text="A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Border Background="BlueViolet" Width="80" Height="115" Margin="15">
                    <TextBlock Text="B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Border Background="DarkGray" Width="80" Height="115" Margin="15">
                    <TextBlock Text="C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Border Background="LawnGreen" Width="80" Height="115" Margin="15">
                    <TextBlock Text="D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Border Background="Yellow" Width="80" Height="115" Margin="5">
                    <TextBlock Text="E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Border Background="HotPink" Width="80" Height="115" Margin="15">
                    <TextBlock Text="F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

            </WrapPanel>

        </Grid>
    </DockPanel>
</Window>



